{
  "manifest_version": 3,
  "name": "Argos In-Stock Filter",
  "version": "1.0.1",
  "description": "Hides out-of-stock products on argos.co.uk",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://www.argos.co.uk/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "argos-in-stock-filter@extension",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.argos.co.uk/*"],
      "js": ["config.js", "content.js"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-on-16.png",
      "48": "icons/icon-on-48.png",
      "128": "icons/icon-on-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Argos In-Stock Filter"
  },
  "icons": {
    "16": "icons/icon-on-16.png",
    "48": "icons/icon-on-48.png",
    "128": "icons/icon-on-128.png"
  }
}
